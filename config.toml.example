# Example configuration for smelly-connect-cli

[vpn]
server = "vpn1.sit.edu.cn"
# Optional session-level keepalive target used by the CLI pool/service layer.
default_keepalive_host = "jwxt.sit.edu.cn"

[pool]
# Number of accounts to connect immediately during startup.
prewarm = 2
# Timeout for establishing a session for one account.
connect_timeout_secs = 20
# Probe interval used for pool health checks.
healthcheck_interval_secs = 60
# Current implementation supports round_robin only.
selection = "round_robin"
# Consecutive failures before a node is removed from normal rotation.
failure_threshold = 3
# Exponential backoff start for failed nodes.
backoff_base_secs = 30
# Exponential backoff cap.
backoff_max_secs = 600
# Allow one request-triggered early recovery attempt when no selectable upstream exists.
allow_request_triggered_probe = true

[[accounts]]
name = "acct-01"
username = "user1"
password = "pass1"

[[accounts]]
name = "acct-02"
username = "user2"
password = "pass2"

[proxy.http]
enabled = true
listen = "127.0.0.1:8080"

[proxy.socks5]
enabled = true
listen = "127.0.0.1:1080"

[routing]
# Bypass route filtering and allow all destinations through the VPN.
allow_all = false

[[routing.domain_rules]]
domain = "*.foo.edu.cn"
port_min = 443
port_max = 443
protocol = "tcp"

[[routing.ip_rules]]
ip_min = "42.62.107.1"
ip_max = "42.62.107.254"
port_min = 1
port_max = 65535
protocol = "all"

[management]
# Optional local management/status API.
enabled = false
listen = "127.0.0.1:9090"

[logging]
# stdout | file | stdout+file | off
mode = "stdout"
# error | warn | info | debug
level = "info"
file = "smelly-connect.log"
